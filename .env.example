# Environment Variables — Copy this to `.env` and fill in your values

# --- PostgreSQL (User Service) ---
DB_URL=jdbc:postgresql://localhost:5432/fitAIdb
DB_USERNAME=postgres
DB_PASSWORD=your_postgres_password

# --- PostgreSQL (Docker Compose) ---
POSTGRES_DB=fitAIdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password

# --- MongoDB Atlas ---
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority

# --- RabbitMQ ---
RABBITMQ_URI=amqps://USERNAME:PASSWORD@your-rabbitmq-host/vhost

# --- Keycloak ---
KEYCLOAK_ISSUER_URI=http://localhost:8080/realms/fitness

# --- Eureka (default works for local dev) ---
EUREKA_URL=http://localhost:8761/eureka/

# --- Google Gemini AI ---
GEMINI_API_KEY=your_gemini_api_key_here
